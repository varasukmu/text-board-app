datasource db {
  provider = "sqlite"
  url      = "file:./text.db"
}

generator client {
  provider = "prisma-client-js"
}

model Block {
  id        Int      @id @default(autoincrement())
  title     String   @default("") // <--- เพิ่มบรรทัดนี้ครับ
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}